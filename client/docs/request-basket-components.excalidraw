    {
      "id": "mFbaz0zmGbe4Jm0P3TIvt",
      "type": "text",
      "x": -2335.3034637485534,
      "y": 906.1897619239451,
      "width": 1319.0774232935057,
      "height": 620.6509572189327,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
